{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_ROOT}/node_modules\" || (cd \"${CLAUDE_PLUGIN_ROOT}\" && npm install --production)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/sync.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/sync-throttled.mjs\""
          }
        ]
      }
    ]
  }
}
