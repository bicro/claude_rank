{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Rank",
  "version": "0.1.0",
  "identifier": "com.clauderank.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:3001 https://clauderank.com https://claude-rank.onrender.com; frame-src https://clauderank.com https://claude-rank.onrender.com http://localhost:3001"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Frisson Labs, CO. (G7FQB386Q9)",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 540,
          "height": 380
        },
        "appPosition": {
          "x": 130,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 410,
          "y": 190
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
