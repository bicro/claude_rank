{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Rank",
  "version": "0.2.17",
  "identifier": "com.clauderank.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:3001 https://clauderank.com https://www.clauderank.com https://claude-rank.onrender.com; frame-src https://clauderank.com https://www.clauderank.com https://claude-rank.onrender.com http://localhost:3001; frame-ancestors *"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["clauderank"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxMTc4MDI5NDRGNUVERUUKUldUdTdmVkVLWUFYUVcreS9VSHhEVENYQ3ExcWxhUjlpN1hRdzllZzRkSTZsWHNsKytTUi9vNXcK",
      "endpoints": [
        "https://github.com/bicro/claude_rank/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Frisson Labs, CO. (G7FQB386Q9)",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 440
        },
        "appPosition": {
          "x": 175,
          "y": 240
        },
        "applicationFolderPosition": {
          "x": 485,
          "y": 240
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
